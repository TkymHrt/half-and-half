#############################################
# Environment template for local development #
#############################################

# Copy this file to `.env.local` (Next.js) and `.env` (Supabase CLI) as needed.
# Fill in the secrets manually and NEVER commit real credentials to git.

# Supabase project configuration
# Public keys are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="public-anon-key"

# Server-side secrets must stay on the backend only.
SUPABASE_SERVICE_ROLE_KEY="service-role-key"
SUPABASE_JWT_SECRET="development-jwt-secret"

# Optional: used by `supabase/config.toml` for local AI assistance.
OPENAI_API_KEY=""

# Optional: cloudflare tunnel token for remote previews.
CLOUDFLARE_TUNNEL_TOKEN=""

# Generic application flags
NEXT_PUBLIC_APP_ENV="development"
